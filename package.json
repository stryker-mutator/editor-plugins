{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "all": "pnpm run clean && pnpm run build && pnpm run lint && pnpm run test",
    "clean": "rimraf -g packages/*/dist/ packages/*/*.tsbuildinfo",
    "build": "lerna run build",
    "test": "lerna run test",
    "lint": "eslint . && pnpm run format",
    "format": "prettier . --check",
    "format:fix": "pnpm run format --write",
    "release": "GH_TOKEN=$(gh auth token) lerna version"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "24.12.0",
    "chai": "^6.2.0",
    "eslint": "10.0.3",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "lerna": "^9.0.0",
    "mocha": "^11.7.4",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.57.0"
  },
  "packageManager": "pnpm@10.28.0"
}
