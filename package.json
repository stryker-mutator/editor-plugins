{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "all": "pnpm run clean && pnpm run build && pnpm run lint && pnpm run test",
    "clean": "rimraf -g packages/*/dist/ packages/*/*.tsbuildinfo",
    "build": "lerna run build",
    "test": "lerna run test",
    "lint": "eslint . && pnpm run format",
    "format": "prettier . --check",
    "format:fix": "pnpm run format --write",
    "release": "GH_TOKEN=$(gh auth token) lerna version"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "24.13.2",
    "chai": "6.2.2",
    "eslint": "10.6.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.7.0",
    "jiti": "2.7.0",
    "lerna": "9.0.7",
    "mocha": "11.7.6",
    "prettier": "3.8.5",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  },
  "packageManager": "pnpm@11.9.0"
}
