{
  "name": "stryker-mutator",
  "displayName": "Stryker Mutation Testing",
  "description": "Test your tests with mutation testing.",
  "version": "0.5.0",
  "publisher": "stryker-mutator",
  "private": true,
  "author": "Jasper van der Veen",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Testing"
  ],
  "type": "commonjs",
  "keywords": [
    "stryker",
    "mutator",
    "strykerjs",
    "mutation",
    "mutation testing",
    "test",
    "testing",
    "stryker mutator",
    "stryker-mutator",
    "mutation server protocol",
    "msp"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stryker-mutator/editor-plugins.git",
    "directory": "packages/vscode-plugin"
  },
  "bugs": {
    "url": "https://github.com/stryker-mutator/editor-plugins/issues"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "category": "Stryker Mutator",
        "command": "strykerMutator.reload",
        "title": "Reload Workspace"
      },
      {
        "category": "Stryker Mutator",
        "command": "strykerMutator.runMutationForFile",
        "title": "Run Mutation Tests for File"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "strykerMutator.runMutationForFile",
          "group": "strykerMutator",
          "when": "resourceExtname =~ /\\.(js|jsx|ts|tsx|mjs|cjs|mts|cts)$/"
        }
      ],
      "editor/title/context": [
        {
          "command": "strykerMutator.runMutationForFile",
          "group": "strykerMutator",
          "when": "resourceExtname =~ /\\.(js|jsx|ts|tsx|mjs|cjs|mts|cts)$/"
        }
      ]
    },
    "configuration": {
      "title": "Stryker Mutator",
      "properties": {
        "strykerMutator.enable": {
          "description": "Enable the Stryker Mutator extension.",
          "scope": "resource",
          "type": "boolean",
          "default": true
        },
        "strykerMutator.watchPattern": {
          "markdownDescription": "Glob pattern for files to watch for changes and trigger mutation discovery. Uses [VS Code glob pattern syntax](https://code.visualstudio.com/docs/editor/glob-patterns#_glob-pattern-syntax).",
          "scope": "resource",
          "type": "string",
          "default": "**/*.{js,ts,jsx,tsx}"
        },
        "strykerMutator.server.path": {
          "description": "Path to the mutation server executable.",
          "scope": "resource",
          "type": "string",
          "default": "node_modules/.bin/stryker"
        },
        "strykerMutator.server.args": {
          "description": "Arguments to pass to the mutation server process when starting.",
          "scope": "resource",
          "type": "array",
          "default": [
            "serve",
            "stdio"
          ]
        },
        "strykerMutator.server.workingDirectory": {
          "description": "Working directory for the Stryker server process. Defaults to the workspace folder if not set.",
          "scope": "resource",
          "type": "string",
          "default": "."
        },
        "strykerMutator.server.configFile": {
          "description": "Optional path to your project's configuration file which will be passed to the server. When not provided, the mutation testing framework will use the default configuration file.",
          "scope": "resource",
          "type": "string"
        }
      }
    }
  },
  "scripts": {
    "all": "pnpm run clean && pnpm run build && pnpm run test",
    "build": "tsdown && tsc -b",
    "watch:tsc": "tsc -b -w",
    "watch:build": "tsdown --watch",
    "clean": "rm -rf dist out \".vscode-test\"",
    "test": "vscode-test",
    "test:linux": "xvfb-run -a vscode-test",
    "pack": "vsce package --no-dependencies",
    "deploy": "vsce publish --azure-credential --no-dependencies",
    "postdeploy": "ovsx publish --pat $OVSX_TOKEN"
  },
  "devDependencies": {
    "@types/chai": "5.2.3",
    "@types/chai-as-promised": "8.0.2",
    "@types/mocha": "10.0.10",
    "@types/node": "24.12.2",
    "@types/sinon": "21.0.1",
    "@types/sinon-chai": "4.0.0",
    "@types/vscode": "1.115.0",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.7.1",
    "chai": "6.2.2",
    "chai-as-promised": "8.0.2",
    "glob": "13.0.6",
    "json-rpc-2.0": "1.7.1",
    "mutation-server-protocol": "workspace:*",
    "ovsx": "0.10.10",
    "rxjs": "7.8.2",
    "sinon": "21.1.0",
    "sinon-chai": "4.0.1",
    "tsdown": "0.21.7",
    "typed-inject": "5.0.0",
    "typescript": "6.0.2"
  },
  "dependencies": {}
}
